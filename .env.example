# Neon Postgres connection string. Provisioned automatically when you create
# a Neon database via Vercel Storage. Pull with `vercel env pull .env.local`.
DATABASE_URL=

# Shared household passphrase. Pick something hard to guess but easy to share
# with your team. Every device entering this string can read and write data.
HOUSEHOLD_SECRET=

# Vercel Blob storage token. Auto-set when you add Vercel Blob to the project.
# Needed for photo/video uploads in the "Saw something new" tracker.
BLOB_READ_WRITE_TOKEN=

# OpenAI API key. Needed for Whisper voice-to-text transcription in the
# "Saw something new" tracker. Cost: ~$0.006 per minute of audio.
# Without it, transcription gracefully degrades — text input still works.
OPENAI_API_KEY=
